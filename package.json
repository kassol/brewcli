{
  "name": "brewcli",
  "version": "0.1.0",
  "description": "Interactive Homebrew TUI built with Bun, TypeScript, and Ink",
  "license": "MIT",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "keywords": [
    "homebrew",
    "brew",
    "tui",
    "cli",
    "bun",
    "ink"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build --compile src/index.tsx --outfile brewcli --external react-devtools-core",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --timeout 60000"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kassol/brewcli.git"
  },
  "bugs": {
    "url": "https://github.com/kassol/brewcli/issues"
  },
  "homepage": "https://github.com/kassol/brewcli#readme",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ink": "^2.0.3",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  }
}
